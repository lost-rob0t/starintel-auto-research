(in-package #:star-lang.core-surface.prototype)

(export '(generate-python-lifecycle-bindings
          generate-typescript-lifecycle-bindings))

(defun generate-python-lifecycle-bindings ()
  (with-output-to-string (stream)
    (format stream "from __future__ import annotations~%~%")
    (format stream "from typing import Any, Literal, NotRequired, TypedDict~%~%")
    (format stream "EnvelopeKind = Literal[\"command\", \"event\", \"reply\", \"ack\", \"error\", \"cancel\"]~%")
    (format stream "AckStatus = Literal[\"accepted\", \"completed\", \"rejected\", \"retry\"]~%~%")
    (format stream "class StarEnvelopeBase(TypedDict):~%")
    (format stream "    star_version: Literal[1]~%")
    (format stream "    kind: EnvelopeKind~%")
    (format stream "    message_id: str~%")
    (format stream "    message_type: str~%")
    (format stream "    actor: str~%")
    (format stream "    correlation_id: str~%")
    (format stream "    attempt: int~%")
    (format stream "    payload: dict[str, Any]~%")
    (format stream "    sender: NotRequired[str]~%")
    (format stream "    causation_id: NotRequired[str]~%")
    (format stream "    idempotency_key: NotRequired[str]~%")
    (format stream "    dataset: NotRequired[str]~%")
    (format stream "    reply_to: NotRequired[str]~%")
    (format stream "    sent_at: NotRequired[str]~%")
    (format stream "    deadline: NotRequired[str]~%~%")
    (format stream "class AckPayload(TypedDict):~%")
    (format stream "    status: AckStatus~%")
    (format stream "    for_message_id: str~%")
    (format stream "    reason: NotRequired[str]~%")
    (format stream "    retry_after_ms: NotRequired[int]~%~%")
    (format stream "class ErrorPayload(TypedDict):~%")
    (format stream "    for_message_id: str~%")
    (format stream "    code: str~%")
    (format stream "    message: str~%")
    (format stream "    retryable: bool~%")
    (format stream "    details: NotRequired[dict[str, Any]]~%~%")
    (format stream "class CancelPayload(TypedDict):~%")
    (format stream "    target_message_id: str~%")
    (format stream "    target_correlation_id: str~%")
    (format stream "    reason: NotRequired[str]~%")))

(defun generate-typescript-lifecycle-bindings ()
  (with-output-to-string (stream)
    (format stream "export type EnvelopeKind = \"command\" | \"event\" | \"reply\" | \"ack\" | \"error\" | \"cancel\";~%")
    (format stream "export type AckStatus = \"accepted\" | \"completed\" | \"rejected\" | \"retry\";~%~%")
    (format stream "export interface StarEnvelopeBase<TPayload extends Record<string, unknown> = Record<string, unknown>> {~%")
    (format stream "  star_version: 1;~%")
    (format stream "  kind: EnvelopeKind;~%")
    (format stream "  message_id: string;~%")
    (format stream "  message_type: string;~%")
    (format stream "  actor: string;~%")
    (format stream "  correlation_id: string;~%")
    (format stream "  attempt: number;~%")
    (format stream "  payload: TPayload;~%")
    (format stream "  sender?: string;~%")
    (format stream "  causation_id?: string;~%")
    (format stream "  idempotency_key?: string;~%")
    (format stream "  dataset?: string;~%")
    (format stream "  reply_to?: string;~%")
    (format stream "  sent_at?: string;~%")
    (format stream "  deadline?: string;~%")
    (format stream "}~%~%")
    (format stream "export interface AckPayload {~%")
    (format stream "  status: AckStatus;~%")
    (format stream "  for_message_id: string;~%")
    (format stream "  reason?: string;~%")
    (format stream "  retry_after_ms?: number;~%")
    (format stream "}~%~%")
    (format stream "export interface ErrorPayload {~%")
    (format stream "  for_message_id: string;~%")
    (format stream "  code: string;~%")
    (format stream "  message: string;~%")
    (format stream "  retryable: boolean;~%")
    (format stream "  details?: Record<string, unknown>;~%")
    (format stream "}~%~%")
    (format stream "export interface CancelPayload {~%")
    (format stream "  target_message_id: string;~%")
    (format stream "  target_correlation_id: string;~%")
    (format stream "  reason?: string;~%")
    (format stream "}~%~%")
    (format stream "export type AckEnvelope = StarEnvelopeBase<AckPayload> & { kind: \"ack\"; message_type: \"star.protocol/ack@1\" };~%")
    (format stream "export type ErrorEnvelope = StarEnvelopeBase<ErrorPayload> & { kind: \"error\"; message_type: \"star.protocol/error@1\" };~%")
    (format stream "export type CancelEnvelope = StarEnvelopeBase<CancelPayload> & { kind: \"cancel\"; message_type: \"star.protocol/cancel@1\" };~%")))
