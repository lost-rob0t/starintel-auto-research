#!/usr/bin/env bash
set -euo pipefail

command -v gh >/dev/null 2>&1 || {
  printf 'error: gh is required\n' >&2
  exit 1
}

repo="${1:-}"
if [[ -z "$repo" ]]; then
  repo="$(gh repo view --json nameWithOwner --jq .nameWithOwner)"
fi

if gh api "repos/${repo}/pages" >/dev/null 2>&1; then
  gh api \
    --method PUT \
    "repos/${repo}/pages" \
    -f build_type=workflow \
    >/dev/null
  action=updated
else
  gh api \
    --method POST \
    "repos/${repo}/pages" \
    -f build_type=workflow \
    >/dev/null
  action=created
fi

printf 'GitHub Pages %s for %s with workflow publishing.\n' "$action" "$repo"
gh api "repos/${repo}/pages" --jq '{html_url, status, build_type, https_enforced}'

gh workflow run pages.yml --repo "$repo" --ref main
printf 'Triggered Org-roam Pages on main.\n'
